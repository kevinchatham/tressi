{
  "name": "tressi",
  "version": "0.0.13",
  "description": "A lightweight, declarative stress testing CLI for modern developers.",
  "license": "SEE LICENSE IN LICENSE.md",
  "author": "kevinchatham",
  "repository": {
    "type": "git",
    "url": "https://github.com/kevinchatham/tressi.git",
    "directory": ""
  },
  "keywords": [
    "performance",
    "load",
    "stress",
    "testing",
    "cli",
    "automation"
  ],
  "type": "commonjs",
  "main": "dist/index.js",
  "bin": {
    "tressi": "dist/cli.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "projects/tressi-cli",
    "projects/tressi-ui"
  ],
  "scripts": {
    "build": "npx rimraf dist && npm run cli:build && npm run ui:build && cp -r projects/tressi-cli/dist dist",
    "clean": "npx rimraf --glob \"**/package-lock.json\" \"**/dist\" \"**/node_modules\" \"**/.angular\"",
    "cli:build": "npm run build -w projects/tressi-cli",
    "cli:run": "npm run run -w projects/tressi-cli",
    "cli:serve": "nodemon --watch projects/tressi-cli/src --ext ts --exec \"npm run build && cd dist && node cli.js serve\"",
    "format:watch": "chokidar \"**/*.{ts,json,md}\" -c \"npm run format\" --ignore \"**/node_modules/**\" --ignore \"**/dist/**\"",
    "format": "prettier --write . --config .prettierrc --ignore-path .prettierignore",
    "lint:inspect": "eslint --inspect-config",
    "lint:watch": "chokidar \"**/*.ts\" -c \"npm run lint\" --ignore \"**/node_modules/**\" --ignore \"**/dist/**\"",
    "lint": "eslint --fix --format unix --config ./eslint.config.mjs .",
    "ui:build": "npm run build -w projects/tressi-ui",
    "ui:serve": "npm run serve -w projects/tressi-ui",
    "test:server": "npx tsx projects/tressi-cli/tests/setup/server.ts",
    "kill": "sudo lsof -i :4200 -i :3108 | awk '$2 ~ /^[0-9]+$/ {print $2}' | xargs sudo kill -9"
  },
  "dependencies": {
    "@acrodata/code-editor": "^0.6.0",
    "@angular/cdk": "^21.0.5",
    "@angular/common": "^21.0.3",
    "@angular/compiler": "^21.0.3",
    "@angular/core": "^21.0.3",
    "@angular/forms": "^21.0.3",
    "@angular/platform-browser": "^21.0.3",
    "@angular/router": "^21.0.3",
    "@codemirror/language-data": "^6.5.2",
    "@hono/node-server": "^1.19.6",
    "@hono/standard-validator": "^0.2.0",
    "@tailwindcss/postcss": "^4.1.17",
    "chalk": "^5.4.1",
    "cli-table3": "^0.6.5",
    "clipboard": "^2.0.11",
    "commander": "^14.0.0",
    "dayjs": "^1.11.19",
    "emoji-toolkit": "^10.0.0",
    "eventemitter3": "^5.0.1",
    "hdr-histogram-js": "^3.0.1",
    "hono": "^4.10.6",
    "human-number": "^2.0.8",
    "kysely": "^0.28.9",
    "marked": "^17.0.2",
    "mermaid": "^11.12.2",
    "ng-apexcharts": "^2.0.3",
    "ngx-markdown": "^21.1.0",
    "ora": "^8.2.0",
    "postcss": "^8.5.6",
    "prismjs": "^1.30.0",
    "rxjs": "~7.8.0",
    "tailwindcss": "^4.1.17",
    "tslib": "^2.3.0",
    "undici": "^7.3.0",
    "unique-names-generator": "^4.7.1",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zod": "4.0.1"
  },
  "devDependencies": {
    "@angular/build": "^21.0.2",
    "@angular/cli": "^21.0.2",
    "@angular/compiler-cli": "^21.0.3",
    "@eslint/eslintrc": "^3.1.0",
    "@types/human-number": "^1.0.2",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^20.0.0",
    "@types/prismjs": "^1.26.6",
    "@vitest/ui": "^4.0.15",
    "chokidar-cli": "^3.0.0",
    "daisyui": "^5.5.5",
    "eslint-formatter-unix": "^8.40.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "jasmine-core": "~5.9.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "nodemon": "^3.1.11",
    "postcss": "^8.5.3",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "rimraf": "^6.1.0",
    "ts-morph": "^25.0.1",
    "tsup": "^8.5.0",
    "tsx": "^4.20.3",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.46.3",
    "vitest": "^4.0.15"
  }
}
