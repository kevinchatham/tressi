{
  "name": "tressi",
  "version": "0.0.13",
  "description": "A lightweight, declarative stress testing CLI for modern developers.",
  "license": "Unlicense",
  "author": "kevinchatham",
  "repository": {
    "type": "git",
    "url": "https://github.com/kevinchatham/tressi.git",
    "directory": ""
  },
  "keywords": [
    "performance",
    "load",
    "stress",
    "testing",
    "cli",
    "automation"
  ],
  "type": "commonjs",
  "main": "dist/index.js",
  "bin": {
    "tressi": "dist/cli.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "projects/tressi-cli",
    "projects/tressi-common",
    "projects/tressi-ui"
  ],
  "scripts": {
    "build": "npx rimraf dist && npm run build:common && npm run build:ui && npm run build:cli",
    "build:cli": "npm run build -w projects/tressi-cli",
    "build:common": "npm run build -w projects/tressi-common",
    "build:ui": "npm run build -w projects/tressi-ui",
    "clean": "npx rimraf --glob \"**/package-lock.json\" \"dist\" \"**/dist\" \"node_modules\" \"**/node_modules\" && npm i",
    "format:watch": "chokidar \"**/*.{ts,json,md}\" -c \"npm run format\" --ignore \"**/node_modules/**\" --ignore \"**/dist/**\"",
    "format": "prettier --write . --config .prettierrc --ignore-path .prettierignore",
    "lint:inspect": "eslint --inspect-config",
    "lint:watch": "chokidar \"**/*.ts\" -c \"npm run lint\" --ignore \"**/node_modules/**\" --ignore \"**/dist/**\"",
    "lint": "eslint --fix --format unix --config ./eslint.config.mjs ."
  },
  "dependencies": {
    "zod": "^3.25.74"
  },
  "devDependencies": {
    "chokidar-cli": "^3.0.0",
    "eslint-formatter-unix": "^8.40.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "prettier": "^3.5.3",
    "rimraf": "^6.1.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.46.3"
  }
}
