{
  "name": "tressi",
  "version": "0.0.13",
  "description": "A modern load testing tool that brings professional API analysis to your workspace.",
  "license": "SEE LICENSE IN LICENSE",
  "author": "kevinchatham",
  "repository": {
    "type": "git",
    "url": "https://github.com/kevinchatham/tressi.git",
    "directory": ""
  },
  "keywords": [
    "load testing",
    "stress testing",
    "performance",
    "benchmark",
    "api testing",
    "http",
    "dashboard",
    "gui",
    "cli",
    "multithreaded",
    "realtime",
    "automation",
    "autocannon",
    "artillery",
    "wrk"
  ],
  "type": "commonjs",
  "main": "dist/index.js",
  "bin": {
    "tressi": "dist/cli.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "projects/cli",
    "projects/ui",
    "projects/shared",
    "projects/e2e"
  ],
  "files": [
    "dist",
    "LICENSE",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "build": "npx rimraf dist && npx rimraf server/dist && npm run cli:build && npm run ui:build && cp -r projects/cli/dist dist",
    "clean": "npx rimraf --glob \"**/package-lock.json\" \"**/dist\" \"**/node_modules\" \"**/.angular\"",
    "cli:build": "npm run build -w projects/cli",
    "cli:run": "npm run run -w projects/cli",
    "cli:serve": "nodemon",
    "docker": "tsx scripts/docker.ts",
    "format:watch": "chokidar \"**/*.{ts,json,md,html,yml,css}\" -c \"npm run format\" --ignore \"**/node_modules/**\" --ignore \"**/dist/**\"",
    "format": "prettier --write . --config .prettierrc --ignore-path .prettierignore",
    "kill": "fuser -k 3108/tcp && fuser -k 4200/tcp && fuser -k 5000/tcp && fuser -k 8000/tcp && fuser -k 8001/tcp",
    "lint:inspect": "eslint --inspect-config",
    "lint:watch": "chokidar \"**/*.ts\" -c \"npm run lint\" --ignore \"**/node_modules/**\" --ignore \"**/dist/**\"",
    "lint": "eslint --fix --format unix --config ./eslint.config.mjs .",
    "postinstall": "npx playwright install --with-deps chromium",
    "start:test:server": "npx tsx projects/e2e/setup/test-server.ts",
    "test": "npm run test:cli && npm run test:ui && npm run test:e2e",
    "test:cli": "npm run test -w projects/cli",
    "test:e2e": "npm run test -w projects/e2e",
    "test:ui": "npm run test -w projects/ui",
    "typecheck": "npm run typecheck -w projects/cli && npm run typecheck -w projects/shared",
    "ui:build": "npm run build -w projects/ui",
    "ui:serve": "npm run serve -w projects/ui"
  },
  "dependencies": {
    "@acrodata/code-editor": "^0.6.0",
    "@codemirror/language-data": "^6.5.2",
    "@hono/node-server": "^1.19.6",
    "@hono/standard-validator": "^0.2.0",
    "@tailwindcss/postcss": "^4.1.17",
    "chalk": "^5.4.1",
    "cli-table3": "^0.6.5",
    "clipboard": "^2.0.11",
    "commander": "^14.0.0",
    "dayjs": "^1.11.19",
    "emoji-toolkit": "^10.0.0",
    "eventemitter3": "^5.0.1",
    "fuse.js": "^7.1.0",
    "hdr-histogram-js": "^3.0.1",
    "hono": "^4.10.6",
    "human-number": "^2.0.8",
    "kysely": "^0.28.9",
    "marked": "^17.0.2",
    "mermaid": "^11.12.2",
    "ng-apexcharts": "^2.0.3",
    "ngx-markdown": "^21.1.0",
    "ora": "^8.2.0",
    "postcss": "^8.5.6",
    "prismjs": "^1.30.0",
    "rxjs": "~7.8.0",
    "tailwindcss": "^4.1.17",
    "tslib": "^2.3.0",
    "undici": "^7.3.0",
    "unique-names-generator": "^4.7.1",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zod": "4.0.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.1.0",
    "@types/human-number": "^1.0.2",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^20.0.0",
    "@types/prismjs": "^1.26.6",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.15",
    "chokidar-cli": "^3.0.0",
    "daisyui": "^5.5.5",
    "eslint-formatter-unix": "^8.40.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "jasmine-core": "~5.9.0",
    "jsdom": "^28.1.0",
    "nodemon": "^3.1.11",
    "postcss": "^8.5.3",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "rimraf": "^6.1.0",
    "ts-morph": "^25.0.1",
    "tsup": "^8.5.0",
    "tsx": "^4.20.3",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.46.3",
    "vitest": "^4.0.18"
  }
}
