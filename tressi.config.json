{
  "$schema": "./tressi.schema.json",
  "options": {
    "durationSec": 10,
    "rampUpTimeSec": 0,
    "useUI": false,
    "silent": false,
    "earlyExitOnError": false,
    "workerMemoryLimit": 128,
    "workerEarlyExit": {
      "enabled": false,
      "monitoringWindowMs": 1000,
      "stopMode": "endpoint"
    }
  },
  "requests": [
    {
      "url": "http://localhost:5000/health",
      "method": "GET",
      "rps": 1
    },
    {
      "url": "http://localhost:5000/success",
      "method": "GET",
      "rps": 10
    }
  ]
}
