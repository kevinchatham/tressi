{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "$schema": {
      "default": "https://raw.githubusercontent.com/kevinchatham/tressi/main/schemas/tressi.schema.v0.0.13.json",
      "type": "string"
    },
    "requests": {
      "default": [],
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "format": "uri"
          },
          "payload": {
            "anyOf": [
              {
                "type": "object",
                "propertyNames": {
                  "type": "string"
                },
                "additionalProperties": {}
              },
              {
                "type": "array",
                "items": {}
              }
            ]
          },
          "method": {
            "default": "GET",
            "type": "string",
            "enum": ["GET", "POST", "PUT", "PATCH", "DELETE", "HEAD", "OPTIONS"]
          },
          "headers": {
            "default": {
              "User-Agent": "Tressi"
            },
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {
              "type": "string"
            }
          },
          "rps": {
            "default": 1,
            "type": "integer",
            "minimum": 1,
            "maximum": 9007199254740991
          }
        },
        "required": ["url", "method", "headers", "rps"],
        "additionalProperties": false
      }
    },
    "options": {
      "type": "object",
      "properties": {
        "durationSec": {
          "default": 10,
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "rampUpTimeSec": {
          "default": 0,
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "exportPath": {
          "default": "./tressi-report",
          "type": "string"
        },
        "silent": {
          "default": false,
          "type": "boolean"
        },
        "headers": {
          "default": {
            "User-Agent": "Tressi"
          },
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "string"
          }
        },
        "threads": {
          "default": 1,
          "description": "Number of worker threads to use (defaults to CPU count)",
          "type": "integer",
          "minimum": 1,
          "maximum": 9007199254740991
        },
        "workerMemoryLimit": {
          "description": "Memory limit per worker in MB",
          "default": 128,
          "type": "integer",
          "minimum": 16,
          "maximum": 512
        },
        "workerEarlyExit": {
          "default": {
            "enabled": false,
            "globalErrorRateThreshold": 0.1,
            "globalErrorCountThreshold": 100,
            "perEndpointThresholds": [],
            "workerExitStatusCodes": [500, 502, 503, 504],
            "monitoringWindowMs": 5000,
            "stopMode": "global"
          },
          "type": "object",
          "properties": {
            "enabled": {
              "default": false,
              "type": "boolean"
            },
            "globalErrorRateThreshold": {
              "default": 0.1,
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "globalErrorCountThreshold": {
              "default": 100,
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            },
            "perEndpointThresholds": {
              "default": [],
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "url": {
                    "type": "string"
                  },
                  "errorRateThreshold": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                  },
                  "errorCountThreshold": {
                    "type": "integer",
                    "exclusiveMinimum": 0,
                    "maximum": 9007199254740991
                  }
                },
                "required": ["url", "errorRateThreshold"],
                "additionalProperties": false
              }
            },
            "workerExitStatusCodes": {
              "default": [500, 502, 503, 504],
              "type": "array",
              "items": {
                "type": "integer",
                "exclusiveMinimum": 0,
                "maximum": 9007199254740991
              }
            },
            "monitoringWindowMs": {
              "default": 5000,
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            },
            "stopMode": {
              "default": "global",
              "type": "string",
              "enum": ["endpoint", "global"]
            }
          },
          "required": [
            "enabled",
            "globalErrorRateThreshold",
            "globalErrorCountThreshold",
            "perEndpointThresholds",
            "workerExitStatusCodes",
            "monitoringWindowMs",
            "stopMode"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "durationSec",
        "rampUpTimeSec",
        "exportPath",
        "silent",
        "headers",
        "threads",
        "workerMemoryLimit",
        "workerEarlyExit"
      ],
      "additionalProperties": false
    }
  },
  "required": ["$schema", "requests", "options"],
  "additionalProperties": false
}
