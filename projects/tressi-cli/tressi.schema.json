{
  "$ref": "#/definitions/TressiConfigSchema",
  "definitions": {
    "TressiConfigSchema": {
      "type": "object",
      "properties": {
        "$schema": {
          "type": "string"
        },
        "requests": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "url": {
                "type": "string",
                "format": "uri"
              },
              "payload": {
                "anyOf": [
                  {
                    "anyOf": [
                      {
                        "type": "object",
                        "additionalProperties": {}
                      },
                      {
                        "type": "array",
                        "items": {}
                      }
                    ]
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "method": {
                "type": "string",
                "enum": [
                  "GET",
                  "POST",
                  "PUT",
                  "PATCH",
                  "DELETE",
                  "HEAD",
                  "OPTIONS"
                ],
                "default": "GET"
              },
              "headers": {
                "anyOf": [
                  {
                    "type": "object",
                    "additionalProperties": {
                      "type": "string"
                    }
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "rps": {
                "type": "integer",
                "minimum": 1,
                "default": 1
              }
            },
            "required": ["url"],
            "additionalProperties": false
          }
        },
        "options": {
          "type": "object",
          "properties": {
            "durationSec": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "default": 10
            },
            "rampUpTimeSec": {
              "type": "integer",
              "minimum": 0
            },
            "exportPath": {
              "type": ["string", "null"]
            },
            "silent": {
              "type": "boolean"
            },
            "headers": {
              "anyOf": [
                {
                  "type": "object",
                  "additionalProperties": {
                    "type": "string"
                  }
                },
                {
                  "type": "null"
                }
              ]
            },
            "threads": {
              "type": "integer",
              "minimum": 1,
              "maximum": 32,
              "description": "Number of worker threads to use (defaults to CPU count)"
            },
            "workerMemoryLimit": {
              "type": "integer",
              "minimum": 16,
              "maximum": 512,
              "description": "Memory limit per worker in MB"
            },
            "workerEarlyExit": {
              "type": "object",
              "properties": {
                "enabled": {
                  "type": "boolean"
                },
                "globalErrorRateThreshold": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1
                },
                "globalErrorCountThreshold": {
                  "type": "integer",
                  "exclusiveMinimum": 0
                },
                "perEndpointThresholds": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "url": {
                        "type": "string"
                      },
                      "errorRateThreshold": {
                        "type": "number",
                        "minimum": 0,
                        "maximum": 1
                      },
                      "errorCountThreshold": {
                        "type": "integer",
                        "exclusiveMinimum": 0
                      }
                    },
                    "required": ["url", "errorRateThreshold"],
                    "additionalProperties": false
                  }
                },
                "workerExitStatusCodes": {
                  "type": "array",
                  "items": {
                    "type": "integer",
                    "exclusiveMinimum": 0
                  }
                },
                "monitoringWindowMs": {
                  "type": "integer",
                  "exclusiveMinimum": 0
                },
                "stopMode": {
                  "type": "string",
                  "enum": ["endpoint", "global"]
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      },
      "required": ["$schema", "requests", "options"],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
