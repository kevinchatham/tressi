{
  "$schema": "./tressi.schema.json",
  "options": {
    "durationSec": 10,
    "rampUpTimeSec": 0,
    "exportPath": "",
    "silent": false,
    "headers": {
      "User-Agent": "Tressi"
    },
    "threads": 1,
    "workerMemoryLimit": 128,
    "workerEarlyExit": {
      "enabled": false,
      "errorRateThreshold": 0,
      "exitStatusCodes": [400, 401, 403, 500, 502, 503, 504],
      "monitoringWindowMs": 5000
    }
  },
  "requests": []
}
