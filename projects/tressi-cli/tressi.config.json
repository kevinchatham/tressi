{
  "$schema": "./tressi.schema.json",
  "options": {
    "durationSec": 100,
    "rampUpTimeSec": 0,
    "useUI": false,
    "silent": false,
    "earlyExitOnError": false,
    "workerMemoryLimit": 128,
    "workerEarlyExit": {
      "enabled": false,
      "monitoringWindowMs": 1000,
      "stopMode": "endpoint"
    }
  },
  "requests": [
    {
      "url": "https://postman-echo.com/get",
      "method": "GET",
      "rps": 1
    },
    {
      "url": "https://postman-echo.com/post",
      "method": "POST",
      "rps": 1,
      "payload": {
        "name": "Tressi Post"
      }
    }
  ]
}
