{
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "lib": ["ES2022", "ES2020.SharedMemory", "WebWorker"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "outDir": "./dist",
    "paths": {
      "@tressi/shared/cli": ["../shared/src/cli/index.ts"],
      "@tressi/shared/common": ["../shared/src/common/index.ts"],
      "@tressi/shared/ui": ["../shared/src/ui/index.ts"]
    },
    "resolveJsonModule": true,
    "rootDir": ".",
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "target": "ES2022",
    "types": ["node"]
  },
  "exclude": ["node_modules"],
  "include": ["src/**/*.ts", "generate-schema.ts"]
}
