{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022", "ES2020.SharedMemory", "WebWorker"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "moduleResolution": "bundler",
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "resolveJsonModule": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "types": ["node"],
    "paths": {
      "@tressi/shared/common": ["../shared/src/common/index.ts"],
      "@tressi/shared/cli": ["../shared/src/cli/index.ts"],
      "@tressi/shared/ui": ["../shared/src/ui/index.ts"]
    }
  },
  "include": ["src/**/*.ts", "generate-schema.ts"],
  "exclude": ["node_modules"]
}
