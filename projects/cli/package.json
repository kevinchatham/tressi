{
  "name": "@tressi/cli",
  "private": true,
  "scripts": {
    "build": "npm run generate:schema && npm run typecheck && tsup",
    "run": "npm run build && node ./dist/cli.js",
    "serve": "npm run build && node ./dist/cli.js serve",
    "generate:schema": "tsx generate-schema.ts",
    "test": "npm run typecheck:tests && vitest run --coverage",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "typecheck:tests": "tsc -p tsconfig.tests.json --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13"
  }
}
