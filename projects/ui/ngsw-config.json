{
  "$schema": "../../node_modules/@angular/service-worker/config/schema.json",
  "assetGroups": [
    {
      "installMode": "prefetch",
      "name": "app",
      "resources": {
        "files": ["/favicon.ico", "/index.html", "/manifest.webmanifest", "/*.css", "/*.js"]
      }
    },
    {
      "installMode": "prefetch",
      "name": "assets",
      "resources": {
        "files": ["/**/*.(png|ttf|md)"]
      },
      "updateMode": "prefetch"
    }
  ],
  "dataGroups": [
    {
      "cacheConfig": {
        "maxAge": "0u",
        "maxSize": 0,
        "strategy": "freshness",
        "timeout": "0u"
      },
      "name": "api-bypass",
      "urls": ["/api/**"]
    }
  ],
  "index": "/index.html",
  "navigationUrls": ["/**", "!/api/**"]
}
