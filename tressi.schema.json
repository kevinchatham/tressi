{
  "$ref": "#/definitions/TressiConfigSchema",
  "definitions": {
    "TressiConfigSchema": {
      "type": "object",
      "properties": {
        "$schema": {
          "type": "string"
        },
        "requests": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "url": {
                "type": "string",
                "format": "uri"
              },
              "payload": {
                "anyOf": [
                  {
                    "type": "object",
                    "additionalProperties": {}
                  },
                  {
                    "type": "array",
                    "items": {}
                  }
                ]
              },
              "method": {
                "type": "string",
                "enum": [
                  "GET",
                  "POST",
                  "PUT",
                  "PATCH",
                  "DELETE",
                  "HEAD",
                  "OPTIONS"
                ],
                "default": "GET"
              },
              "headers": {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                }
              },
              "rps": {
                "type": "integer",
                "minimum": 1,
                "default": 1
              }
            },
            "required": ["url"],
            "additionalProperties": false
          }
        },
        "options": {
          "type": "object",
          "properties": {
            "durationSec": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "default": 10
            },
            "rampUpTimeSec": {
              "type": "integer",
              "minimum": 0,
              "default": 0
            },
            "exportPath": {
              "type": ["string", "boolean"]
            },
            "useUI": {
              "type": "boolean",
              "default": true
            },
            "silent": {
              "type": "boolean",
              "default": false
            },
            "earlyExitOnError": {
              "type": "boolean",
              "default": false
            },
            "errorRateThreshold": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "errorCountThreshold": {
              "type": "integer",
              "exclusiveMinimum": 0
            },
            "errorStatusCodes": {
              "type": "array",
              "items": {
                "type": "integer",
                "exclusiveMinimum": 0
              }
            },
            "headers": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            },
            "threads": {
              "type": "integer",
              "minimum": 1,
              "maximum": 32,
              "description": "Number of worker threads to use (defaults to CPU count)"
            },
            "workerMemoryLimit": {
              "type": "integer",
              "minimum": 16,
              "maximum": 512,
              "default": 128,
              "description": "Memory limit per worker in MB"
            },
            "workerEarlyExit": {
              "type": "object",
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "default": false
                },
                "globalErrorRateThreshold": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1
                },
                "globalErrorCountThreshold": {
                  "type": "integer",
                  "exclusiveMinimum": 0
                },
                "perEndpointThresholds": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "url": {
                        "type": "string"
                      },
                      "errorRateThreshold": {
                        "type": "number",
                        "minimum": 0,
                        "maximum": 1
                      },
                      "errorCountThreshold": {
                        "type": "integer",
                        "exclusiveMinimum": 0
                      }
                    },
                    "required": ["url", "errorRateThreshold"],
                    "additionalProperties": false
                  }
                },
                "workerExitStatusCodes": {
                  "type": "array",
                  "items": {
                    "type": "integer",
                    "exclusiveMinimum": 0
                  }
                },
                "monitoringWindowMs": {
                  "type": "integer",
                  "exclusiveMinimum": 0,
                  "default": 1000
                },
                "stopMode": {
                  "type": "string",
                  "enum": ["endpoint", "global"],
                  "default": "endpoint"
                }
              },
              "additionalProperties": false,
              "default": {
                "enabled": false,
                "monitoringWindowMs": 1000,
                "stopMode": "endpoint"
              }
            }
          },
          "additionalProperties": false,
          "default": {
            "durationSec": 10,
            "rampUpTimeSec": 0,
            "useUI": true,
            "silent": false,
            "earlyExitOnError": false,
            "workerMemoryLimit": 128,
            "workerEarlyExit": {
              "enabled": false,
              "monitoringWindowMs": 1000,
              "stopMode": "endpoint"
            }
          }
        }
      },
      "required": ["$schema", "requests"],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
