{
  "$ref": "#/definitions/TressiConfigSchema",
  "definitions": {
    "TressiConfigSchema": {
      "type": "object",
      "properties": {
        "$schema": {
          "type": "string"
        },
        "requests": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "url": {
                "type": "string",
                "format": "uri"
              },
              "payload": {
                "anyOf": [
                  {
                    "type": "object",
                    "additionalProperties": {}
                  },
                  {
                    "type": "array",
                    "items": {}
                  }
                ]
              },
              "method": {
                "type": "string",
                "enum": [
                  "GET",
                  "POST",
                  "PUT",
                  "PATCH",
                  "DELETE",
                  "HEAD",
                  "OPTIONS"
                ],
                "default": "GET"
              },
              "headers": {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                }
              }
            },
            "required": ["url"],
            "additionalProperties": false
          }
        },
        "options": {
          "type": "object",
          "properties": {
            "workers": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "default": 10
            },
            "durationSec": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "default": 10
            },
            "rampUpTimeSec": {
              "type": "integer",
              "minimum": 0,
              "default": 0
            },
            "rps": {
              "type": "number",
              "exclusiveMinimum": 0,
              "default": 1
            },
            "exportPath": {
              "type": ["string", "boolean"]
            },
            "useUI": {
              "type": "boolean",
              "default": true
            },
            "silent": {
              "type": "boolean",
              "default": false
            },
            "earlyExitOnError": {
              "type": "boolean",
              "default": false
            },
            "errorRateThreshold": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "errorCountThreshold": {
              "type": "integer",
              "exclusiveMinimum": 0
            },
            "errorStatusCodes": {
              "type": "array",
              "items": {
                "type": "integer",
                "exclusiveMinimum": 0
              }
            },
            "headers": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            }
          },
          "additionalProperties": false
        }
      },
      "required": ["$schema", "requests"],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
