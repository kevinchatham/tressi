{
  "$ref": "#/definitions/TressiConfigSchema",
  "definitions": {
    "TressiConfigSchema": {
      "type": "object",
      "properties": {
        "$schema": {
          "type": "string",
          "default": "https://raw.githubusercontent.com/kevinchatham/tressi/main/schemas/tressi.schema.v0.0.13.json"
        },
        "requests": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "url": {
                "type": "string",
                "format": "uri"
              },
              "payload": {
                "anyOf": [
                  {
                    "type": "object",
                    "additionalProperties": {}
                  },
                  {
                    "type": "array",
                    "items": {}
                  }
                ]
              },
              "method": {
                "type": "string",
                "enum": [
                  "GET",
                  "POST",
                  "PUT",
                  "PATCH",
                  "DELETE",
                  "HEAD",
                  "OPTIONS"
                ],
                "default": "GET"
              },
              "headers": {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                },
                "default": {
                  "User-Agent": "Tressi"
                }
              },
              "rps": {
                "type": "integer",
                "minimum": 1,
                "default": 1
              }
            },
            "required": ["url"],
            "additionalProperties": false
          },
          "default": []
        },
        "options": {
          "type": "object",
          "properties": {
            "durationSec": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "default": 10
            },
            "rampUpTimeSec": {
              "type": "integer",
              "minimum": 0,
              "default": 0
            },
            "exportPath": {
              "type": "string",
              "default": "./tressi-report"
            },
            "silent": {
              "type": "boolean",
              "default": false
            },
            "headers": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              },
              "default": {
                "User-Agent": "Tressi"
              }
            },
            "threads": {
              "type": "integer",
              "minimum": 1,
              "description": "Number of worker threads to use (defaults to CPU count)",
              "default": 1
            },
            "workerMemoryLimit": {
              "type": "integer",
              "minimum": 16,
              "maximum": 512,
              "default": 128,
              "description": "Memory limit per worker in MB"
            },
            "workerEarlyExit": {
              "type": "object",
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "default": false
                },
                "globalErrorRateThreshold": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1,
                  "default": 0.1
                },
                "globalErrorCountThreshold": {
                  "type": "integer",
                  "exclusiveMinimum": 0,
                  "default": 100
                },
                "perEndpointThresholds": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "url": {
                        "type": "string"
                      },
                      "errorRateThreshold": {
                        "type": "number",
                        "minimum": 0,
                        "maximum": 1
                      },
                      "errorCountThreshold": {
                        "type": "integer",
                        "exclusiveMinimum": 0
                      }
                    },
                    "required": ["url", "errorRateThreshold"],
                    "additionalProperties": false
                  },
                  "default": []
                },
                "workerExitStatusCodes": {
                  "type": "array",
                  "items": {
                    "type": "integer",
                    "exclusiveMinimum": 0
                  },
                  "default": [500, 502, 503, 504]
                },
                "monitoringWindowMs": {
                  "type": "integer",
                  "exclusiveMinimum": 0,
                  "default": 5000
                },
                "stopMode": {
                  "type": "string",
                  "enum": ["endpoint", "global"],
                  "default": "global"
                }
              },
              "additionalProperties": false,
              "default": {
                "enabled": false,
                "globalErrorRateThreshold": 0.1,
                "globalErrorCountThreshold": 100,
                "perEndpointThresholds": [],
                "workerExitStatusCodes": [500, 502, 503, 504],
                "monitoringWindowMs": 5000,
                "stopMode": "global"
              }
            }
          },
          "additionalProperties": false,
          "default": {}
        }
      },
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
