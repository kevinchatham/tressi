{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "default": {
    "$schema": "https://raw.githubusercontent.com/kevinchatham/tressi/main/schemas/tressi.schema.v0.0.13.json",
    "requests": [],
    "options": {
      "durationSec": 10,
      "rampUpDurationSec": 0,
      "exportPath": "",
      "silent": false,
      "headers": {
        "User-Agent": "Tressi"
      },
      "threads": 1,
      "workerMemoryLimit": 128,
      "workerEarlyExit": {
        "enabled": false,
        "errorRateThreshold": 0,
        "exitStatusCodes": [],
        "monitoringWindowMs": 1000
      }
    }
  },
  "type": "object",
  "properties": {
    "$schema": {
      "description": "A URL to the JSON schema for this configuration file.",
      "type": "string"
    },
    "requests": {
      "description": "An array of request configurations.",
      "minItems": 1,
      "type": "array",
      "items": {
        "default": {
          "url": "",
          "payload": {},
          "method": "GET",
          "headers": {
            "User-Agent": "Tressi"
          },
          "rps": 1,
          "rampUpDurationSec": 0,
          "earlyExit": {
            "enabled": false,
            "errorRateThreshold": 0,
            "exitStatusCodes": [],
            "monitoringWindowMs": 1000
          }
        },
        "type": "object",
        "properties": {
          "url": {
            "description": "The URL to send the request to.",
            "type": "string",
            "format": "uri"
          },
          "payload": {
            "description": "The request payload. Can be a JSON object or an array.",
            "anyOf": [
              {
                "type": "object",
                "propertyNames": {
                  "type": "string"
                },
                "additionalProperties": {}
              },
              {
                "type": "array",
                "items": {}
              }
            ]
          },
          "method": {
            "description": "The HTTP method to use for the request. Defaults to GET.",
            "type": "string",
            "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"]
          },
          "headers": {
            "description": "Headers to be sent with this specific request. Merged with global headers.",
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {
              "type": "string"
            }
          },
          "rps": {
            "description": "Per-endpoint requests per second limit. Defaults to 1.",
            "type": "integer",
            "minimum": 1,
            "maximum": 9007199254740991
          },
          "rampUpDurationSec": {
            "description": "Per-endpoint ramp-up time in seconds. If 0, uses global rampUpDurationSec. Defaults to 0.",
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          },
          "earlyExit": {
            "description": "Optional early exit configuration for this specific endpoint",
            "default": {
              "enabled": false,
              "errorRateThreshold": 0,
              "exitStatusCodes": [],
              "monitoringWindowMs": 1000
            },
            "type": "object",
            "properties": {
              "enabled": {
                "description": "Enable early exit for this endpoint",
                "type": "boolean"
              },
              "errorRateThreshold": {
                "description": "Error rate threshold (0.0-1.0)",
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "exitStatusCodes": {
                "description": "HTTP status codes that trigger immediate endpoint stop",
                "type": "array",
                "items": {
                  "type": "integer",
                  "exclusiveMinimum": 0,
                  "maximum": 9007199254740991
                }
              },
              "monitoringWindowMs": {
                "description": "Time window in milliseconds for threshold calculation",
                "type": "integer",
                "exclusiveMinimum": 0,
                "maximum": 9007199254740991
              }
            },
            "required": [
              "enabled",
              "errorRateThreshold",
              "exitStatusCodes",
              "monitoringWindowMs"
            ],
            "additionalProperties": false
          }
        },
        "required": [
          "url",
          "payload",
          "method",
          "headers",
          "rps",
          "rampUpDurationSec",
          "earlyExit"
        ],
        "additionalProperties": false
      }
    },
    "options": {
      "description": "Configuration options for the test runner.",
      "default": {
        "durationSec": 10,
        "rampUpDurationSec": 0,
        "exportPath": "",
        "silent": false,
        "headers": {
          "User-Agent": "Tressi"
        },
        "threads": 1,
        "workerMemoryLimit": 128,
        "workerEarlyExit": {
          "enabled": false,
          "errorRateThreshold": 0,
          "exitStatusCodes": [],
          "monitoringWindowMs": 1000
        }
      },
      "type": "object",
      "properties": {
        "durationSec": {
          "description": "The total duration of the test in seconds. Defaults to 10.",
          "type": "integer",
          "exclusiveMinimum": 0,
          "maximum": 9007199254740991
        },
        "rampUpDurationSec": {
          "description": "The time in seconds to ramp up to the target RPS. Defaults to 0.",
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "exportPath": {
          "description": "The base path for the exported report. If not provided, no report will be generated.",
          "type": "string"
        },
        "silent": {
          "description": "Suppress all console output. Defaults to false.",
          "type": "boolean"
        },
        "headers": {
          "description": "Global headers to be sent with every request.",
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "string"
          }
        },
        "threads": {
          "description": "Number of worker threads to use (defaults to CPU count)",
          "type": "integer",
          "minimum": 1,
          "maximum": 9007199254740991
        },
        "workerMemoryLimit": {
          "description": "Memory limit per worker in MB",
          "type": "integer",
          "minimum": 16,
          "maximum": 512
        },
        "workerEarlyExit": {
          "description": "Global early exit configuration (acts as default for endpoints without specific config)",
          "default": {
            "enabled": false,
            "errorRateThreshold": 0,
            "exitStatusCodes": [],
            "monitoringWindowMs": 1000
          },
          "type": "object",
          "properties": {
            "enabled": {
              "description": "Enable early exit for this endpoint",
              "type": "boolean"
            },
            "errorRateThreshold": {
              "description": "Error rate threshold (0.0-1.0)",
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "exitStatusCodes": {
              "description": "HTTP status codes that trigger immediate endpoint stop",
              "type": "array",
              "items": {
                "type": "integer",
                "exclusiveMinimum": 0,
                "maximum": 9007199254740991
              }
            },
            "monitoringWindowMs": {
              "description": "Time window in milliseconds for threshold calculation",
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            }
          },
          "required": [
            "enabled",
            "errorRateThreshold",
            "exitStatusCodes",
            "monitoringWindowMs"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "durationSec",
        "rampUpDurationSec",
        "exportPath",
        "silent",
        "headers",
        "threads",
        "workerMemoryLimit",
        "workerEarlyExit"
      ],
      "additionalProperties": false
    }
  },
  "required": ["$schema", "requests", "options"],
  "additionalProperties": false
}
