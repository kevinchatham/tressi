{
  "$ref": "#/definitions/TressiConfigSchema",
  "definitions": {
    "TressiConfigSchema": {
      "type": "object",
      "properties": {
        "$schema": {
          "type": "string"
        },
        "requests": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "url": {
                "type": "string",
                "format": "uri"
              },
              "payload": {
                "anyOf": [
                  {
                    "type": "object",
                    "additionalProperties": {}
                  },
                  {
                    "type": "array",
                    "items": {}
                  }
                ]
              },
              "method": {
                "type": "string",
                "enum": [
                  "GET",
                  "POST",
                  "PUT",
                  "PATCH",
                  "DELETE",
                  "HEAD",
                  "OPTIONS"
                ],
                "default": "GET"
              },
              "headers": {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                }
              },
              "rps": {
                "type": "integer",
                "minimum": 1,
                "default": 1
              }
            },
            "required": ["url"],
            "additionalProperties": false
          }
        },
        "options": {
          "type": "object",
          "properties": {
            "durationSec": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "default": 10
            },
            "rampUpTimeSec": {
              "type": "integer",
              "minimum": 0,
              "default": 0
            },
            "exportPath": {
              "type": ["string", "boolean"]
            },
            "useUI": {
              "type": "boolean",
              "default": true
            },
            "silent": {
              "type": "boolean",
              "default": false
            },
            "earlyExitOnError": {
              "type": "boolean",
              "default": false
            },
            "errorRateThreshold": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "errorCountThreshold": {
              "type": "integer",
              "exclusiveMinimum": 0
            },
            "errorStatusCodes": {
              "type": "array",
              "items": {
                "type": "integer",
                "exclusiveMinimum": 0
              }
            },
            "headers": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            },
            "adaptiveConcurrency": {
              "type": "object",
              "properties": {
                "maxConcurrency": {
                  "type": "integer",
                  "exclusiveMinimum": 0,
                  "default": 10
                },
                "targetLatency": {
                  "type": "integer",
                  "exclusiveMinimum": 0,
                  "default": 100
                },
                "memoryThreshold": {
                  "type": "number",
                  "minimum": 0.1,
                  "maximum": 0.95,
                  "default": 0.8
                },
                "enabled": {
                  "type": "boolean",
                  "default": true
                },
                "minConcurrency": {
                  "type": "integer",
                  "exclusiveMinimum": 0,
                  "default": 1
                }
              },
              "additionalProperties": false,
              "default": {}
            }
          },
          "additionalProperties": false,
          "default": {
            "durationSec": 10,
            "rampUpTimeSec": 0,
            "useUI": true,
            "silent": false,
            "earlyExitOnError": false,
            "adaptiveConcurrency": {
              "maxConcurrency": 10,
              "targetLatency": 100,
              "memoryThreshold": 0.8,
              "enabled": true,
              "minConcurrency": 1
            }
          }
        }
      },
      "required": ["$schema", "requests"],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
